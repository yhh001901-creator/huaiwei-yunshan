
.container.data-v-cdfe2409 {
  min-height: 100vh;
  background: linear-gradient(180deg, #FFF9F5 0%, #FFF5EB 100%);
  padding: 0 32rpx;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
}
.header.data-v-cdfe2409 {
  padding-top: 80rpx;
  padding-bottom: 40rpx;
  text-align: center;
}
.header-inner.data-v-cdfe2409 {
  display: flex;
  flex-direction: column;
  align-items: center;
}
.logo-circle.data-v-cdfe2409 {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #F97316, #FB923C);
