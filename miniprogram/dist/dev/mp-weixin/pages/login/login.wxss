.input-group.data-v-cdfe2409 {
  margin-bottom: 24rpx;
}
.label.data-v-cdfe2409 {
  display: block;
  font-size: 26rpx;
  color: #334155;
  font-weight: 500;
  margin-bottom: 10rpx;
}
.input-wrap.data-v-cdfe2409 {
  width: 100%;
  background: #F8FAFC;
  border: 2rpx solid #E2E8F0;
  border-radius: 16rpx;
}
.input.data-v-cdfe2409 {
  width: 100%;
  padding: 22rpx 24rpx;
  font-size: 30rpx;
  box-sizing: border-box;
  border: none;
  background: transparent;
}
