  color: #94A3B8;
  margin-top: 4rpx;
}
.form-area.data-v-cdfe2409 {
  max-width: 680rpx;
  margin: 0 auto;
}
.tabs.data-v-cdfe2409 {
  display: flex;
  background: #F1F5F9;
  border-radius: 16rpx;
  padding: 6rpx;
  margin-bottom: 24rpx;
}
.tab.data-v-cdfe2409 {
