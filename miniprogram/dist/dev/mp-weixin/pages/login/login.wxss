  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
  box-shadow: 0 8rpx 24rpx rgba(249,115,22,0.3);
}
.logo-icon.data-v-cdfe2409 {
  font-size: 50rpx;
}
.title.data-v-cdfe2409 {
